# Copy to backend/.env and fill in. Never commit .env.

# --- LLM provider ---
# Provider is swappable behind a thin wrapper. "groq" uses the OpenAI-compatible API.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Alternative provider, wired but inactive unless LLM_PROVIDER=anthropic:
ANTHROPIC_API_KEY=

# --- Market data (CoinGecko Demo API; works keyless) ---
COINGECKO_API_KEY=

# --- Retrieval (ChromaDB, local + persisted) ---
CHROMA_PERSIST_DIR=./data/chroma
KB_RELEVANCE_THRESHOLD=0.3

# --- Redis (Phase 2) ---
REDIS_URL=redis://localhost:6379/0
PRICE_CACHE_TTL_SECONDS=60
RATE_LIMIT_PER_MINUTE=30

# --- PostgreSQL (Phase 2) ---
DATABASE_URL=postgresql+psycopg://markets:markets@localhost:5432/markets

# --- LangFuse (Phase 2; optional — app runs fine if blank) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- CORS (Phase 4; frontend origins allowed to call the API) ---
# Comma-separated. Defaults cover the Vite dev server (5173) and a local preview build (4173).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
